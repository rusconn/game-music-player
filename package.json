{
  "name": "game-music-player",
  "private": true,
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check && prettier --cache --check .",
    "build": "astro build",
    "preview": "firebase serve --project game-music-player-web",
    "deploy": "firebase deploy --project game-music-player-web"
  },
  "dependencies": {
    "music-metadata": "11.13.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^7.0.3",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.6.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
