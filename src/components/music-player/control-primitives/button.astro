---
import type { HTMLAttributes } from "astro/types";

type Props = Omit<HTMLAttributes<"button">, "type">;

const { props } = Astro;
---

<button type="button" {...props}>
  <slot />
</button>

<style>
  button {
    inline-size: 1.375rem;
    aspect-ratio: 1;
    position: relative;
    background-color: transparent;
    border: none;
    cursor: pointer;
    color: currentColor;

    &:disabled {
      cursor: not-allowed;
      color: #aaa;
    }
  }
</style>
