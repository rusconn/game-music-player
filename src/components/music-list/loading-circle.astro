---
import type { HTMLAttributes } from "astro/types";

type Props = Omit<HTMLAttributes<"div">, "class" | "hidden">;

const { props } = Astro;
---

<div class="loading-circle" {...props} hidden>
  <div class="loader"></div>
</div>

<style>
  .loading-circle {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;

    &[hidden] {
      display: none;
    }

    .loader {
      inline-size: 0.875rem;
      block-size: 0.875rem;
      border: 0.175rem solid currentColor;
      border-block-start-color: #555;
      border-radius: 100vmax;
      animation: spin 0.8s linear infinite;
    }
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
</style>
